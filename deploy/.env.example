# Generate a strong value before deployment, for example: openssl rand -base64 32
DBMOCK_POSTGRES_PASSWORD=change-this-random-password
DBMOCK_IMAGE=ghcr.io/pika/db-mock:latest
POSTGRES_IMAGE=postgres:17-alpine
DBMOCK_PUBLIC_URL=http://localhost:8080
DBMOCK_BIND_ADDRESS=0.0.0.0
DBMOCK_PORT=8080
# First-run default only. After setup, change the active IANA timezone in System settings.
DBMOCK_TIMEZONE=Asia/Shanghai
DBMOCK_SESSION_DURATION=720h
# Hard ceiling for the runtime offline-image upload policy configured in System settings.
DBMOCK_MAX_UPLOAD_BYTES=53687091200

# Optional built-in TLS. Put files below DBMOCK_TLS_DIR and use container paths here.
DBMOCK_TLS_DIR=./tls
DBMOCK_TLS_CERT_FILE=
DBMOCK_TLS_KEY_FILE=
